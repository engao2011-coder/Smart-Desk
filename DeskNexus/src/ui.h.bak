/*
 * ui.h — TFT Display UI Helpers
 *
 * Colour palette, layout constants, and drawing routines for the
 * 240×320 portrait TFT (ILI9341) on the ESP32-2432S028R (CYD).
 *
 * Screen layout (portrait, 240 wide × 320 tall):
 *
 *  ┌────────────────────────┐ y=0
 *  │   Status bar  (24 px)  │  WiFi icon, date string
 *  ├────────────────────────┤ y=24
 *  │                        │
 *  │   Clock   (88 px)      │  HH:MM large
 *  │                        │
 *  ├────────────────────────┤ y=112
 *  │   Weather  (80 px)     │  Temp + condition label
 *  ├────────────────────────┤ y=192
 *  │                        │
 *  │   Panel  (96 px)       │  Prayer times or Stock list
 *  │                        │
 *  ├────────────────────────┤ y=288
 *  │   Tabs (32 px)         │  [Prayer] [Stocks] [Settings]
 *  └────────────────────────┘ y=320
 *
 * Fonts used: TFT_eSPI built-in Free fonts (FreeSansBold24pt7b etc.)
 */

#pragma once

#include <TFT_eSPI.h>
#include "config.h"
#include "weather.h"
#include "prayer.h"
#include "stocks.h"

// ---------------------------------------------------------------------------
// Colour palette (RGB565)
// ---------------------------------------------------------------------------
#define C_BG           0x1082   // Very dark navy background
#define C_PANEL        0x2124   // Slightly lighter panel
#define C_ACCENT       0xE945   // Coral/red accent
#define C_TEXT_PRIMARY 0xFFFF   // White
#define C_TEXT_SEC     0xC618   // Light grey
#define C_TEXT_DIM     0x7BEF   // Dark grey
#define C_GREEN        0x07E0   // Pure green (price up)
#define C_RED          0xF800   // Pure red  (price down)
#define C_GOLD         0xFEA0   // Gold/amber (prayer highlight)
#define C_TAB_ACTIVE   0xE945   // Same as accent
#define C_TAB_INACTIVE 0x2945   // Dark teal
#define C_SEPARATOR    0x39E7   // Mid-grey line

// ---------------------------------------------------------------------------
// Layout constants
// ---------------------------------------------------------------------------
#define LAYOUT_STATUS_Y    0
#define LAYOUT_STATUS_H    24
#define LAYOUT_CLOCK_Y     24
#define LAYOUT_CLOCK_H     88
#define LAYOUT_WEATHER_Y   112
#define LAYOUT_WEATHER_H   80
#define LAYOUT_PANEL_Y     192
#define LAYOUT_PANEL_H     96
#define LAYOUT_TABS_Y      288
#define LAYOUT_TABS_H      32

#define SCREEN_W  240
#define SCREEN_H  320

// Tab indices
#define TAB_PRAYER   0
#define TAB_STOCKS   1
#define TAB_SETTINGS 2
#define TAB_COUNT    3

namespace UI {

static TFT_eSPI tft = TFT_eSPI();
static int   activeTab    = TAB_PRAYER;
static bool  needsRedraw  = true;
static bool  dimmed       = false;
static unsigned long lastTouchMs = 0;

// ── Touch calibration ─────────────────────────────────────────────────────
static uint16_t calData[5] = TOUCH_CAL_DATA;

// ── Small helpers ──────────────────────────────────────────────────────────
static void hline(int y, uint16_t color = C_SEPARATOR) {
    tft.drawFastHLine(0, y, SCREEN_W, color);
}

static void fillPanel(int y, int h, uint16_t color = C_PANEL) {
    tft.fillRect(0, y, SCREEN_W, h, color);
}

// ---------------------------------------------------------------------------
// Init
// ---------------------------------------------------------------------------
static void begin() {
    // Backlight via LEDC PWM
    ledcSetup(0, 5000, 8);
    ledcAttachPin(TFT_BL_PIN, 0);
    ledcWrite(0, BACKLIGHT_FULL_DUTY);

    tft.init();
    tft.setRotation(0);          // Portrait: 240×320
    tft.fillScreen(C_BG);
    tft.setTextDatum(TL_DATUM);
    tft.setSwapBytes(true);

    lastTouchMs = millis();
}

// ---------------------------------------------------------------------------
// Backlight control
// ---------------------------------------------------------------------------
static void setDimmed(bool d) {
    if (d == dimmed) return;
    dimmed = d;
    ledcWrite(0, d ? BACKLIGHT_DIM_DUTY : BACKLIGHT_FULL_DUTY);
}

static void wake() {
    lastTouchMs = millis();
    setDimmed(false);
}

static void checkDim() {
    if (SCREEN_TIMEOUT_MS == 0) return;
    if (!dimmed && (millis() - lastTouchMs) >= SCREEN_TIMEOUT_MS) {
        setDimmed(true);
    }
}

// ---------------------------------------------------------------------------
// Status bar (y=0..23)
// ---------------------------------------------------------------------------
static void drawStatusBar(bool wifiOk, const String& dateStr, const String& ipStr) {
    tft.fillRect(0, LAYOUT_STATUS_Y, SCREEN_W, LAYOUT_STATUS_H, C_BG);

    // WiFi icon / indicator
    uint16_t wifiColor = wifiOk ? C_GREEN : C_RED;
    tft.fillCircle(10, 12, 5, wifiColor);

    tft.setTextSize(1);
    tft.setFreeFont(nullptr);   // default small font

    // IP address — always right-aligned; gold in AP mode, dim when connected
    tft.setTextColor(wifiOk ? C_TEXT_DIM : C_GOLD, C_BG);
    int iw = tft.textWidth(ipStr);
    tft.setCursor(SCREEN_W - iw - 4, 8);
    tft.print(ipStr);

    // Date string — centred in the space between the WiFi dot and the IP field
    int available = SCREEN_W - iw - 4 - 20;   // from x=20 to start of IP
    tft.setTextColor(C_TEXT_SEC, C_BG);
    int dw = tft.textWidth(dateStr);
    int dx = 20 + (available - dw) / 2;
    tft.setCursor(dx, 8);
    tft.print(dateStr);

    hline(LAYOUT_STATUS_Y + LAYOUT_STATUS_H - 1);
}

// ---------------------------------------------------------------------------
// Clock section (y=24..111)
// ---------------------------------------------------------------------------
static void drawClock(const struct tm& t) {
    fillPanel(LAYOUT_CLOCK_Y, LAYOUT_CLOCK_H, C_BG);

    char hmBuf[6];
    snprintf(hmBuf, sizeof(hmBuf), "%02d:%02d", t.tm_hour, t.tm_min);

    // Large HH:MM (centred)
    tft.setTextColor(C_TEXT_PRIMARY, C_BG);
    tft.setFreeFont(&FreeSansBold24pt7b);
    int tw = tft.textWidth(hmBuf);
    tft.setCursor((SCREEN_W - tw) / 2, LAYOUT_CLOCK_Y + 56);
    tft.print(hmBuf);

    hline(LAYOUT_CLOCK_Y + LAYOUT_CLOCK_H - 1);
}

// ---------------------------------------------------------------------------
// Weather section (y=112..191)
// ---------------------------------------------------------------------------
static void drawWeather() {
    fillPanel(LAYOUT_WEATHER_Y, LAYOUT_WEATHER_H, C_BG);

    if (!Weather::current.valid) {
        tft.setFreeFont(nullptr);
        tft.setTextSize(1);
        tft.setTextColor(C_TEXT_DIM, C_BG);
        tft.setCursor(8, LAYOUT_WEATHER_Y + 32);
        tft.print("Weather: loading...");
        hline(LAYOUT_WEATHER_Y + LAYOUT_WEATHER_H - 1);
        return;
    }

    const Weather::Data& w = Weather::current;
    uint16_t accent = Weather::iconColor(w.iconCode);

    // City name
    tft.setFreeFont(nullptr);
    tft.setTextSize(1);
    tft.setTextColor(C_TEXT_SEC, C_BG);
    tft.setCursor(8, LAYOUT_WEATHER_Y + 4);
    tft.print(w.cityName);

    // Temperature — large
    char tempBuf[12];
    const char* unit = (strcmp(OWM_UNITS, "imperial") == 0) ? "°F" : "°C";
    snprintf(tempBuf, sizeof(tempBuf), "%.0f%s", w.temp, unit);

    tft.setFreeFont(&FreeSansBold18pt7b);
    tft.setTextColor(accent, C_BG);
    tft.setCursor(8, LAYOUT_WEATHER_Y + 52);
    tft.print(tempBuf);

    // Condition label
    tft.setFreeFont(nullptr);
    tft.setTextSize(1);
    tft.setTextColor(C_TEXT_SEC, C_BG);
    tft.setCursor(8, LAYOUT_WEATHER_Y + 60);
    tft.print(Weather::iconLabel(w.iconCode));

    // Humidity + Wind (right side)
    char humBuf[16], windBuf[16];
    snprintf(humBuf,  sizeof(humBuf),  "Hum: %.0f%%", w.humidity);
    snprintf(windBuf, sizeof(windBuf), "Wind: %.1fm/s", w.windSpeedMs);
    tft.setTextColor(C_TEXT_DIM, C_BG);
    int col2 = 140;
    tft.setCursor(col2, LAYOUT_WEATHER_Y + 20);
    tft.print(humBuf);
    tft.setCursor(col2, LAYOUT_WEATHER_Y + 36);
    tft.print(windBuf);

    // Feels-like
    char flBuf[20];
    snprintf(flBuf, sizeof(flBuf), "Feels: %.0f%s", w.feelsLike, unit);
    tft.setCursor(col2, LAYOUT_WEATHER_Y + 52);
    tft.print(flBuf);

    hline(LAYOUT_WEATHER_Y + LAYOUT_WEATHER_H - 1);
}

// ---------------------------------------------------------------------------
// Tab bar (y=192..223)
// ---------------------------------------------------------------------------
static const char* TAB_LABELS[TAB_COUNT] = {"Prayer", "Stocks", "Settings"};
static const int   TAB_W = SCREEN_W / TAB_COUNT;

static void drawTabs() {
    for (int i = 0; i < TAB_COUNT; i++) {
        uint16_t bg = (i == activeTab) ? C_TAB_ACTIVE : C_TAB_INACTIVE;
        uint16_t fg = C_TEXT_PRIMARY;
        tft.fillRect(i * TAB_W, LAYOUT_TABS_Y, TAB_W, LAYOUT_TABS_H, bg);
        tft.setFreeFont(nullptr);
        tft.setTextSize(1);
        tft.setTextColor(fg, bg);
        int tw = tft.textWidth(TAB_LABELS[i]);
        tft.setCursor(i * TAB_W + (TAB_W - tw) / 2,
                      LAYOUT_TABS_Y + (LAYOUT_TABS_H - 8) / 2);
        tft.print(TAB_LABELS[i]);
    }
    hline(LAYOUT_TABS_Y + LAYOUT_TABS_H - 1);
}

// Handle a touch in the tab bar; returns true if tab changed
static bool handleTabTouch(uint16_t tx, uint16_t ty) {
    if (ty < LAYOUT_TABS_Y || ty >= LAYOUT_TABS_Y + LAYOUT_TABS_H) return false;
    int tab = tx / TAB_W;
    if (tab < 0 || tab >= TAB_COUNT) return false;
    if (tab != activeTab) {
        activeTab   = tab;
        needsRedraw = true;
        return true;
    }
    return false;
}

// ---------------------------------------------------------------------------
// Prayer panel (y=224..319)
// ---------------------------------------------------------------------------
static void drawPrayerPanel() {
    fillPanel(LAYOUT_PANEL_Y, LAYOUT_PANEL_H, C_PANEL);

    tft.setFreeFont(nullptr);
    tft.setTextSize(1);

    if (!Prayer::current.valid) {
        tft.setTextColor(C_TEXT_DIM, C_PANEL);
        tft.setCursor(8, LAYOUT_PANEL_Y + 40);
        tft.print("Prayer times: loading...");
        return;
    }

    // Show all 6 prayer times in two columns
    const int ROW_H = 15;
    const int COL1  = 4;
    const int COL2  = 122;
    int col = COL1;
    int y   = LAYOUT_PANEL_Y + 6;

    for (int i = 0; i < Prayer::PRAYER_COUNT; i++) {
        bool isNext = (i == Prayer::current.nextIndex);
        uint16_t fg = isNext ? C_GOLD : C_TEXT_SEC;
        uint16_t bg = isNext ? C_PANEL : C_PANEL;

        if (isNext) {
            // Highlight background
            tft.fillRect(col, y - 2, 116, ROW_H + 2,
                         tft.color565(40, 40, 0));
        }

        tft.setTextColor(fg, isNext ? tft.color565(40, 40, 0) : C_PANEL);
        tft.setCursor(col + 2, y);
        tft.print(Prayer::current.prayers[i].name);
        tft.setCursor(col + 70, y);
        tft.print(Prayer::current.prayers[i].time);

        y += ROW_H;
        if (i == 2) {   // switch to second column after Dhuhr
            col = COL2;
            y   = LAYOUT_PANEL_Y + 6;
        }
    }

    // Countdown to next prayer
    int minsLeft = Prayer::minutesUntilNext();
    if (minsLeft >= 0 && Prayer::current.nextIndex >= 0) {
        char buf[32];
        snprintf(buf, sizeof(buf), "Next in %dh %02dm",
                 minsLeft / 60, minsLeft % 60);
        tft.setTextColor(C_GOLD, C_PANEL);
        int tw = tft.textWidth(buf);
        tft.setCursor((SCREEN_W - tw) / 2, LAYOUT_PANEL_Y + LAYOUT_PANEL_H - 12);
        tft.print(buf);
    }
}

// ---------------------------------------------------------------------------
// Stocks panel (y=224..319)
// ---------------------------------------------------------------------------
static void drawStocksPanel() {
    fillPanel(LAYOUT_PANEL_Y, LAYOUT_PANEL_H, C_PANEL);

    tft.setFreeFont(nullptr);
    tft.setTextSize(1);

    int n = Stocks::symbolCount();
    if (n == 0) {
        tft.setTextColor(C_TEXT_DIM, C_PANEL);
        tft.setCursor(8, LAYOUT_PANEL_Y + 40);
        tft.print("No stocks configured.");
        return;
    }

    // Show up to 4 quotes in a list
    const int ROW_H = 22;
    int y = LAYOUT_PANEL_Y + 4;
    int shown = 0;

    for (int i = 0; i < MAX_STOCKS && shown < 4; i++) {
        const Stocks::Quote& q = Stocks::quotes[i];
        if (!q.valid) continue;

        uint16_t pctColor = (q.changePct >= 0) ? C_GREEN : C_RED;
        char priceBuf[12], pctBuf[10];
        snprintf(priceBuf, sizeof(priceBuf), "$%.2f", q.price);
        snprintf(pctBuf,   sizeof(pctBuf),   "%+.2f%%", q.changePct);

        // Symbol (left)
        tft.setTextColor(C_TEXT_PRIMARY, C_PANEL);
        tft.setCursor(6, y + 2);
        tft.print(q.symbol);

        // Price (centre)
        tft.setTextColor(C_TEXT_SEC, C_PANEL);
        tft.setCursor(80, y + 2);
        tft.print(priceBuf);

        // Change % (right, coloured)
        tft.setTextColor(pctColor, C_PANEL);
        int pw = tft.textWidth(pctBuf);
        tft.setCursor(SCREEN_W - pw - 6, y + 2);
        tft.print(pctBuf);

        // Alert indicator
        if (q.alertTriggered) {
            tft.fillCircle(SCREEN_W - pw - 16, y + 6, 4, C_GOLD);
        }

        hline(y + ROW_H - 1, C_SEPARATOR);
        y += ROW_H;
        shown++;
    }

    if (n == 0 || shown == 0) {
        tft.setTextColor(C_TEXT_DIM, C_PANEL);
        tft.setCursor(8, LAYOUT_PANEL_Y + 40);
        tft.print("Fetching quotes...");
    }
}

// ---------------------------------------------------------------------------
// Settings panel (y=192..287)
// ---------------------------------------------------------------------------
static void drawSettingsPanel(bool wifiOk, const String& localAddr) {
    fillPanel(LAYOUT_PANEL_Y, LAYOUT_PANEL_H, C_PANEL);

    tft.setFreeFont(nullptr);
    tft.setTextSize(1);
    tft.setTextColor(C_TEXT_SEC, C_PANEL);

    int y = LAYOUT_PANEL_Y + 8;
    const int ROW = 14;

    tft.setCursor(8, y); tft.print("WiFi:");
    tft.setTextColor(wifiOk ? C_GREEN : C_GOLD, C_PANEL);
    tft.setCursor(60, y);
    tft.print(wifiOk ? "Connected" : "AP Mode");

    y += ROW;
    tft.setTextColor(C_TEXT_PRIMARY, C_PANEL);
    tft.setCursor(8, y); tft.print("http://"); tft.print(localAddr);

    y += ROW;
    tft.setTextColor(C_TEXT_SEC, C_PANEL);
    tft.setCursor(8, y); tft.print("City:  " OWM_CITY_NAME);

    y += ROW;
    tft.setCursor(8, y); tft.print("Prayer method: " + String(PRAYER_METHOD));

    y += ROW;
    tft.setCursor(8, y); tft.print("UTC offset: " + String(NTP_UTC_OFFSET_SEC / 3600) + "h");

    y += ROW;
    tft.setTextColor(C_TEXT_DIM, C_PANEL);
    tft.setCursor(8, y); tft.print("v1.0  DeskNexus ESP32");
}

// ---------------------------------------------------------------------------
// Notification banner (temporary overlay at top of panel)
// ---------------------------------------------------------------------------
static unsigned long bannerExpiry = 0;
static char bannerText[64] = {};

static void showBanner(const char* text, uint32_t durationMs = 5000) {
    strncpy(bannerText, text, sizeof(bannerText) - 1);
    bannerExpiry = millis() + durationMs;
}

static void drawBannerIfActive() {
    if (millis() >= bannerExpiry) return;
    tft.fillRect(0, LAYOUT_PANEL_Y, SCREEN_W, 20, C_ACCENT);
    tft.setFreeFont(nullptr);
    tft.setTextSize(1);
    tft.setTextColor(C_TEXT_PRIMARY, C_ACCENT);
    int tw = tft.textWidth(bannerText);
    tft.setCursor((SCREEN_W - tw) / 2, LAYOUT_PANEL_Y + 6);
    tft.print(bannerText);
}

// ---------------------------------------------------------------------------
// Full screen redraw
// ---------------------------------------------------------------------------
static void redraw(bool wifiOk, const String& ip, const String& ipAddr,
                   const struct tm& t, const String& dateStr) {
    drawStatusBar(wifiOk, dateStr, ipAddr);
    drawClock(t);
    drawWeather();
    drawTabs();

    switch (activeTab) {
        case TAB_PRAYER:   drawPrayerPanel();                   break;
        case TAB_STOCKS:   drawStocksPanel();                   break;
        case TAB_SETTINGS: drawSettingsPanel(wifiOk, ip);       break;
    }

    drawBannerIfActive();
    needsRedraw = false;
}

// ---------------------------------------------------------------------------
// Partial updates (called every second without full redraw)
// ---------------------------------------------------------------------------
static void updateClock(const struct tm& t) {
    drawClock(t);
}

static void updateWeather() {
    drawWeather();
}

static void updatePanel() {
    switch (activeTab) {
        case TAB_PRAYER:   drawPrayerPanel();  break;
        case TAB_STOCKS:   drawStocksPanel();  break;
        default: break;
    }
}

// ---------------------------------------------------------------------------
// Splash / boot screen
// ---------------------------------------------------------------------------
static void showSplash() {
    tft.fillScreen(C_BG);
    tft.setFreeFont(&FreeSansBold18pt7b);
    tft.setTextColor(C_ACCENT, C_BG);
    String title = "DeskNexus";
    int tw = tft.textWidth(title);
    tft.setCursor((SCREEN_W - tw) / 2, 140);
    tft.print(title);

    tft.setFreeFont(nullptr);
    tft.setTextSize(1);
    tft.setTextColor(C_TEXT_DIM, C_BG);
    String sub = "ESP32 Desk Clock";
    tw = tft.textWidth(sub);
    tft.setCursor((SCREEN_W - tw) / 2, 166);
    tft.print(sub);
}

static void showSplashStatus(const char* msg) {
    tft.fillRect(0, 190, SCREEN_W, 20, C_BG);
    tft.setFreeFont(nullptr);
    tft.setTextSize(1);
    tft.setTextColor(C_TEXT_SEC, C_BG);
    int tw = tft.textWidth(msg);
    tft.setCursor((SCREEN_W - tw) / 2, 192);
    tft.print(msg);
}

} // namespace UI
